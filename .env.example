# zapiska configuration
# Copy this to .env and fill in your values.
# Every variable here is optional except ADMIN_TOKEN.

# ──────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────

# Admin bearer token for /api/admin/* endpoints. Generate one with:
#   openssl rand -base64 32
ADMIN_TOKEN="change-me-to-a-random-secret"

# ──────────────────────────────────────────────────────────────
# Identity & networking (defaults assume the original author's site)
# ──────────────────────────────────────────────────────────────

# Listen address. zapiska sits behind a reverse proxy, so localhost-only is fine.
# Set to 0.0.0.0:3000 if you run it directly / in Docker.
# BIND_ADDR=127.0.0.1:3000

# The canonical origin of the main site this server accepts comments/webmentions for.
# Set this to YOUR site, e.g. https://example.com
# PUBLIC_TARGET_ORIGIN=https://nithitsuki.com

# The single origin the public read API may be called from (CORS).
# Set this to YOUR site's origin. Use "*" only for public-read testing.
# ALLOWED_CORS_ORIGIN=https://nithitsuki.com

# SQLite file path. In Docker, use a mounted volume (see docker-compose-example.yml).
# DATABASE_PATH=./comments.db

# ──────────────────────────────────────────────────────────────
# GitHub enrichment (optional but recommended)
# ──────────────────────────────────────────────────────────────

# Personal access token (no scopes needed). Raises the GitHub API rate
# limit from 60/hr to 5000/hr when commenters provide a github_username.
# GITHUB_TOKEN=ghp_your_pat

# ──────────────────────────────────────────────────────────────
# Limits & tuning
# ──────────────────────────────────────────────────────────────

# Max chars of stored content / author name / request body bytes.
# MAX_CONTENT_LEN=2000
# MAX_AUTHOR_LEN=100
# MAX_BODY_SIZE=8192

# Outbound HTTP timeout (ms) for source/GitHub fetches.
# FETCH_TIMEOUT_MS=4000

# Bounded webmention worker queue capacity. Overflow returns 503.
# WORKER_BACKLOG=64

# ──────────────────────────────────────────────────────────────
# Spam protection
# ──────────────────────────────────────────────────────────────

# Honeypot form field name. Hidden from real users; bots auto-fill it.
# HONEYPOT_FIELD=website

# Max native comments per submitter IP per day. 0 = unlimited.
# MAX_COMMENTS_PER_IP_PER_DAY=50

# Max webmentions per source domain per hour. 0 = unlimited.
# MAX_WEBMENTIONS_PER_DOMAIN_PER_HOUR=10

# Store submitter IPs in the database for spam analysis. Default false (privacy).
# STORE_IP_ADDRESS=false

# ──────────────────────────────────────────────────────────────
# Moderation
# ──────────────────────────────────────────────────────────────

# Default status for new comments:
#   "pending"  = manual review required (default, safest)
#   "approved"= auto-publish, your engine can still revert later
# DEFAULT_COMMENT_STATUS=pending

# Optional webhook endpoint. zapiska POSTs the enriched payload to this
# URL after every submission. See docs/moderation-engine.md.
# MODERATION_WEBHOOK_URL=http://localhost:9000/webhook

# "async" = fire-and-forget (default). "sync" = zapiska waits for the
# webhook to respond and applies the returned action immediately.
# MODERATION_WEBHOOK_MODE=async

# Maximum nesting depth for threaded replies. 0 = nesting disabled. Clamped 0-10.
# MAX_THREAD_DEPTH=0

# ──────────────────────────────────────────────────────────────
# Cloudflare Turnstile bot protection (optional, off by default)
# ──────────────────────────────────────────────────────────────

# When true, native comment submissions must include a valid
# `cf-turnstile-response` token from the Cloudflare Turnstile widget.
# Get a sitekey + secret from https://dash.cloudflare.com → Turnstile.
# OFF by default; comment submissions are accepted without it.
# TURNSTILE_ENABLED=false

# The secret (starts with "0x4AAAAAAA..."). Required when ENABLED=true.
# Never logged or written to disk. The public sitekey goes in your HTML, not here.
# TURNSTILE_SECRET_KEY=

# Override the siteverify endpoint. Defaults to Cloudflare's public endpoint.
# Only change for tests / proxies.
# TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# ──────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────

# tracing filter directive. Try "debug" for verbose, "warn" for errors only.
# RUST_LOG=info