# zapiska configuration
# Copy this to .env and fill in your values.

# Required: admin bearer token for the moderation dashboard
# Generate one: openssl rand -base64 32
ADMIN_TOKEN="change-me-to-a-random-secret"

# Optional overrides (shown with their defaults)
# BIND_ADDR=127.0.0.1:3000
# PUBLIC_TARGET_ORIGIN=https://nithitsuki.com
# ALLOWED_CORS_ORIGIN=https://nithitsuki.com
# DATABASE_PATH=./comments.db
# GITHUB_TOKEN=
# MAX_CONTENT_LEN=2000
# MAX_AUTHOR_LEN=100
# MAX_BODY_SIZE=8192
# FETCH_TIMEOUT_MS=4000
# WORKER_BACKLOG=64
# RUST_LOG=info
